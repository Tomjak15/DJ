# Lokalny PostgreSQL, np. postgres://postgres:postgres@localhost:5432/abw_os
DATABASE_URL=

# W produkcji ustaw dlugi, losowy sekret. Render wygeneruje go automatycznie.
JWT_SECRET=

# Puste oznacza API pod tym samym adresem co frontend.
API_URL=

# Opcjonalne ustawienia lokalne.
PORT=8080
NODE_ENV=development
